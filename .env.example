SERVER_PORT=8200
SERVER_HOST=0.0.0.0

# SML PostgreSQL server (192.168.2.248)
SML_DB_HOST=192.168.2.248
SML_DB_PORT=5432
SML_DB_USER=postgres
SML_DB_PASSWORD=sml
SML_DB_SSLMODE=disable

# Connection pool (per tenant DB)
SML_DB_MAX_CONNS=10
SML_DB_MIN_CONNS=2

# ── Tenant resolution (priority order) ──────────────────────────────────────
# 1. X-Tenant header     (new apps)
# 2. databaseName header (BillFlow / SML legacy — sent automatically)
# 3. DEFAULT_TENANT      (single-tenant deployments, no header needed)
DEFAULT_TENANT=

# Whitelist: comma-separated DB names that are allowed to connect.
# Leave empty to allow all databases on the SML server (LAN-only deployments).
# Recommended for prod: list only the DBs this instance should serve.
# ALLOWED_TENANTS=sml1,sml1_2026,stp1
ALLOWED_TENANTS=

# ── Auth ────────────────────────────────────────────────────────────────────
# Keys are accepted via:
#   X-Api-Key header  (new apps)
#   guid header       (BillFlow uses this — set SHOPEE_SML_GUID to match)
#   api_key query param (curl/testing)
#
# Set this to the same value as SHOPEE_SML_GUID in BillFlow's .env
API_KEYS=dev-key,your-prod-key
